{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "maison-claire",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path');const m={'html':'text/html','css':'text/css','js':'application/javascript','jpg':'image/jpeg','jpeg':'image/jpeg','png':'image/png','gif':'image/gif','svg':'image/svg+xml','ico':'image/x-icon'};h.createServer((q,r)=>{let u=q.url==='/'?'/index.html':decodeURIComponent(q.url);let fp=p.join(process.cwd(),u);f.readFile(fp,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');return}const ext=p.extname(fp).slice(1);r.writeHead(200,{'Content-Type':m[ext]||'application/octet-stream'});r.end(d)})}).listen(3000,()=>console.log('Server running on port 3000'))"],
      "port": 3000
    }
  ]
}
